---
import BaseLayout from '../layouts/BaseLayout.astro';
const allPosts = Object.values(
  import.meta.glob('./posts/*.md', { eager: true }),
);
const pageTitle = 'Blog';
---

<BaseLayout pageTitle={pageTitle}>
  <!-- ===================== DOBRA 1 ===================== -->
  <!-- Vídeo em destaque à esquerda e texto de apresentação à direita -->
  <section class="hero">
    <h2 class="section-title hero-title">
      Falando, refletindo e fazendo música!
    </h2>
  </section>

  <!-- ===================== DOBRA 2 ===================== -->
  <!-- Cartões com temas principais da vida musical -->
  <section class="themes">
    <div class="container">
      <ul>
        {
          allPosts.map((post: any) => (
            <li style="margin: 40px; font-size: 1.5rem;">
              <a href={post.url}>{post.frontmatter.title}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
  <!-- ===================== DOBRA 3 ===================== -->
</BaseLayout>
