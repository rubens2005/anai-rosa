---
import BaseLayout from '../layouts/BaseLayout.astro';
const allPosts = Object.values(
  import.meta.glob('./posts/*.md', { eager: true }),
);
const pageTitle = 'Blog';
---

<BaseLayout pageTitle={pageTitle}>
  <!-- ===================== DOBRA 1 ===================== -->
  <!-- Vídeo em destaque à esquerda e texto de apresentação à direita -->
  <section class="bg-base-800 text-act-200">
    <h2 class="text-center text-[2.20rem] leading-9 pt-6 pb-6 font-bold">
      Falando, refletindo e fazendo música!
    </h2>
  </section>

  <!-- ===================== DOBRA 2 ===================== -->
  <!-- Cartões com temas principais da vida musical -->
  <section>
    <div>
      <ul>
        {
          allPosts.map((post: any) => {
            return (
              post.frontmatter.aparecerNaLista == 'sim' && (
                <li class="m-10 text-2xl">
                  <a href={post.url}>{post.frontmatter.title}</a>
                </li>
              )
            );
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>
